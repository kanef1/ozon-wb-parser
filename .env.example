# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL
POSTGRES_DB=ozon_wb_parser
POSTGRES_USER=parser_user
POSTGRES_PASSWORD=parser_password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Парсинг (интервал в минутах)
PARSE_INTERVAL_MINUTES=30

# VK
VK_COMMUNITY_TOKEN=your-vk-community-token
VK_GROUP_ID=your-vk-group-id

# Домен сервиса (для ссылок в уведомлениях)
SITE_DOMAIN=https://yourdomain.com

# Прокси с российским IP (нужен при деплое на зарубежный сервер)
# Форматы: http://user:pass@host:port  или  socks5://user:pass@host:port
# WB_PROXY_URL=http://user:pass@host:port
